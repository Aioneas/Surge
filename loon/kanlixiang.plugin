#!name=看理想VIP解锁 + 资料页去推广昵称
#!desc=保留原 VIP 模块逻辑，并将 user/profile 改为仅清理推广昵称，避免重复命中（Loon 版）
#!author=baby + Aioneas
#!homepage=https://github.com/Aioneas/Surge
#!icon=https://raw.githubusercontent.com/Aioneas/Surge/main/Icon/kanlixiang.png

[Script]
http-response ^https?:\/\/api\.vistopia\.com\.cn\/api\/v2\/(reader\/(section-detail|detail)|user\/home|vip\/buy-list|services\/play-token) script-path=https://raw.githubusercontent.com/Aioneas/Surge/main/Script/kanlixiang_vip.js, requires-body=true, timeout=60, tag=看理想VIP原逻辑
http-response ^https?:\/\/api\.vistopia\.com\.cn\/api\/v2\/user\/profile(?:\?.*)?$ script-path=https://raw.githubusercontent.com/Aioneas/Surge/main/Script/klx_profile_clean.js, requires-body=true, timeout=60, tag=看理想资料页去推广昵称

[MITM]
hostname = api.vistopia.com.cn
