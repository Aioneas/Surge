#!name=AdGuard Mobile Ads（Surge适配）@Aioneas
#!desc=将 AdGuard/uBO – Mobile Ads 中可稳定映射到 Surge 的移动广告网络域名规则独立拆分为模块。说明：Surge 为网络层拦截，不包含浏览器元素隐藏 / 脚本替换等扩展专属能力。
#!author=AdGuard Team + Aioneas
#!homepage=https://github.com/Aioneas/Surge
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Advertising.png
#!category=Aioneas

[Rule]
# Auto-generated by tools/build_surge_adlists.py
# Block domains: 923
# Allow domains: 2
# 仅在命中拦截域名且未命中放行域名时才 REJECT；未命中则继续走主配置的原始分流
AND,((DOMAIN-SET,https://raw.githubusercontent.com/Aioneas/Surge/main/List/adguard-mobile-ads.block.domainset,extended-matching),(NOT,((DOMAIN-SET,https://raw.githubusercontent.com/Aioneas/Surge/main/List/adguard-mobile-ads.allow.domainset,extended-matching)))),REJECT
