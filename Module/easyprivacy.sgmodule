#!name=EasyPrivacy（Surge适配）@Aioneas
#!desc=将 EasyPrivacy 中可稳定映射到 Surge 的追踪 / 统计域名规则独立拆分为模块。说明：Surge 为网络层拦截，不包含浏览器元素隐藏 / 脚本替换 / 参数移除等扩展专属能力。
#!author=EasyList + Aioneas
#!homepage=https://github.com/Aioneas/Surge
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Advertising.png
#!category=Aioneas

[Rule]
# Auto-generated by tools/build_surge_adlists.py
# Block domains: 6384
# Allow domains: 4
# 仅在命中拦截域名且未命中放行域名时才 REJECT；未命中则继续走主配置的原始分流
AND,((DOMAIN-SET,https://raw.githubusercontent.com/Aioneas/Surge/main/List/easyprivacy.block.domainset,extended-matching),(NOT,((DOMAIN-SET,https://raw.githubusercontent.com/Aioneas/Surge/main/List/easyprivacy.allow.domainset,extended-matching)))),REJECT
